<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      BLE is functionally required, but declared required="false" on purpose: a
      hard requirement lets some launchers/installers hide or block a sideload on
      a device that doesn't advertise the feature flag (exactly the kind of
      surprise the RayNeo X3 Pro can spring). The real gate is the runtime adapter
      check in ShintaiBleClient.connect(), which fails gracefully to Disconnected
      when BLE is absent or off — so we always install, then degrade cleanly.
    -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />

    <!--
      RayNeo XR runtime features, declared to match RayNeo's own apps. NOTE: on
      testing, these ALONE did NOT flip the launcher out of the 720×960 portrait
      phone-compat window — the `com.rayneo.mercury.app` meta-data below is the actual
      signal that earns the fullscreen 1280×480 landscape canvas. Kept as the confirmed-
      working pairing (and belt-and-suspenders for the XR runtime binding).
      required="false" keeps the phone fallback installable on non-RayNeo devices
      (same reasoning as bluetooth_le above).
    -->
    <uses-feature android:name="com.rayneo.airuntime" android:required="false" />
    <uses-feature android:name="com.rayneo.xr.runtime" android:required="false" />

    <!--
      We connect to a KNOWN device by MAC and never scan, so we only need
      BLUETOOTH_CONNECT (API 31+). No BLUETOOTH_SCAN and no location permission —
      that's deliberate: scanning gets starved by the glasses' own BLE stack.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShintaiGlass">

        <!--
          RayNeo "Mercury" (X3 Pro codename = MercuryLiteXR) fullscreen-app marker.
          RayNeo's own apps declare this application meta-data and get the fullscreen
          1280×480 LANDSCAPE canvas; without it the launcher boxes third-party apps into
          a 720×960 PORTRAIT phone window, which the compositor scales to a squished
          ~360px column per eye. This — not the com.rayneo.* uses-feature flags above —
          is the signal the launcher actually keys off. Verified against RayNeoLiveAI's
          manifest (`<meta-data com.rayneo.mercury.app = true>` at application level).
        -->
        <meta-data android:name="com.rayneo.mercury.app" android:value="true" />

        <!--
          No orientation lock: phones rotate freely (portrait or landscape), and
          the UI picks mono vs. side-by-side stereo from the surface aspect ratio.
          The glasses' display is fixed-landscape hardware, so they stay landscape.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ShintaiGlass">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
